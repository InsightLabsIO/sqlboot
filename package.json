{
  "name": "sqlboot",
  "version": "1.0.3",
  "description": "Cross-platform npm CLI for Oracle SQL*Plus, Docker Oracle XE, rlwrap, and the sqlboot command.",
  "license": "MIT",
  "bin": {
    "sqlboot": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "sqlboot",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "npm run build && bash -n sqlboot && npm run test",
    "prepack": "npm run build",
    "test": "vitest run",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "oracle",
    "sqlplus",
    "docker",
    "oracle-xe",
    "cli",
    "installer",
    "sqlboot"
  ],
  "engines": {
    "node": ">=16"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
